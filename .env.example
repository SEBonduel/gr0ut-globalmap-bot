# Copie ce fichier en `.env` pour les tests en local (ne pas committer).
# En production (GitHub Actions), ces valeurs vont dans les *Secrets* du repo.

WG_APP_ID=ton_application_id_wargaming
WG_CLAN_ID=500165786
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# --- Optionnel (valeurs par défaut sensées) ---
# WG_API_BASE=https://api.worldoftanks.eu   # cluster EU
# TZ_NAME=Europe/Paris
# LEAD_MIN=45     # borne basse de la fenêtre "avant bataille" (minutes)
# LEAD_MAX=75     # borne haute -> notif ~1h avant
# DRY_RUN=1       # n'envoie rien à Discord, affiche le message dans la console
